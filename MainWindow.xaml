<Window x:Class="Lab1App4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab1App4"
        mc:Ignorable="d"
        Title="MainWindow" Height="250" Width="500"  WindowStartupLocation="CenterScreen">
    <Grid>

        <TextBlock Text="Год" HorizontalAlignment="Left" Margin="28,27,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="95" Height="17"/>
        <TextBlock Text="Месяц" HorizontalAlignment="Left" Margin="179,27,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="95" Height="17"/>
        <TextBlock Text="Число" HorizontalAlignment="Left" Margin="328,27,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="95" Height="17"/>

        <ComboBox x:Name="ComboYear" HorizontalAlignment="Left" Margin="28,60,0,0" VerticalAlignment="Top" Width="120" SelectionChanged="ComboYearMonth_SelectionChanged" />
        <ComboBox x:Name="ComboMonth" HorizontalAlignment="Left" Margin="179,60,0,0" VerticalAlignment="Top" Width="120" SelectionChanged="ComboYearMonth_SelectionChanged" />
        <ComboBox x:Name="ComboDay" HorizontalAlignment="Left" Margin="328,60,0,0" VerticalAlignment="Top" Width="120" IsEnabled="False" SelectionChanged="ComboDay_SelectionChanged" />
       

        <TextBlock x:Name="TextResult" Text="Сначала выберите год и месяц." HorizontalAlignment="Left" Margin="28,143,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="57" Width="420"/>


    </Grid>
</Window>
